<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="documents_minio_sync.DownloadProgressBar">
        <div class="o_download_progress_bar bg-light border rounded p-2 mb-2">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="o_download_filename text-truncate" t-esc="props.download.filename"/>
                <span class="o_download_percentage text-muted small">
                    <t t-esc="props.download.progress"/>%
                </span>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-primary" role="progressbar" 
                     t-att-style="progressStyle"
                     t-att-aria-valuenow="props.download.progress" 
                     aria-valuemin="0" 
                     aria-valuemax="100"/>
            </div>
            <div class="o_download_size text-muted small mt-1">
                <t t-esc="formattedSize"/> / <t t-esc="totalSize"/>
            </div>
        </div>
    </t>
</templates>
