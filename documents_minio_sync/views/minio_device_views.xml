<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Device List View -->
    <record id="view_minio_device_tree" model="ir.ui.view">
        <field name="name">minio.device.tree</field>
        <field name="model">minio.device</field>
        <field name="arch" type="xml">
            <tree string="Devices" decoration-success="status == 'online'" decoration-muted="status == 'offline'">
                <header>
                    <button name="action_check_all" string="Check All Status" display="always" type="object" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="client_id"/>
                <field name="user_id"/>
                <field name="ip_address"/>
                <field name="version"/>
                <field name="last_seen"/>
                <field name="status" widget="badge" decoration-success="status == 'online'" decoration-muted="status == 'offline'"/>
                <button name="action_check_status" string="Check Status" type="object" icon="fa-refresh" class="btn-primary"/>
            </tree>
        </field>
    </record>

    <!-- Device Form View -->
    <record id="view_minio_device_form" model="ir.ui.view">
        <field name="name">minio.device.form</field>
        <field name="model">minio.device</field>
        <field name="arch" type="xml">
            <form string="Device">
                <header>
                    <button name="action_check_status" string="Check Status" type="object" class="oe_highlight"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="client_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="ip_address"/>
                            <field name="version"/>
                            <field name="last_seen"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Access Logs" name="access_logs">
                            <field name="access_log_ids" readonly="1">
                                <tree default_order="timestamp desc">
                                    <field name="timestamp"/>
                                    <field name="name"/>
                                    <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'failed'"/>
                                    <field name="details"/>
                                </tree>
                            </field>
                        </page>
                        <page string="System Logs" name="service_logs">
                            <field name="log_ids" readonly="1">
                                <tree default_order="timestamp desc">
                                    <field name="timestamp"/>
                                    <field name="level" widget="badge" decoration-danger="level == 'error'" decoration-warning="level == 'warning'"/>
                                    <field name="message"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Access Log List View -->
    <record id="view_minio_access_log_tree" model="ir.ui.view">
        <field name="name">minio.access.log.tree</field>
        <field name="model">minio.access.log</field>
        <field name="arch" type="xml">
            <tree string="Access Logs" create="false" edit="false">
                <field name="timestamp"/>
                <field name="device_id"/>
                <field name="user_id"/>
                <field name="name"/>
                <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'failed'"/>
                <field name="ip_address"/>
            </tree>
        </field>
    </record>

    <!-- Log List View -->
    <record id="view_minio_service_log_tree" model="ir.ui.view">
        <field name="name">minio.service.log.tree</field>
        <field name="model">minio.service.log</field>
        <field name="arch" type="xml">
            <tree string="Service Logs" create="false" edit="false" decoration-danger="level == 'error'">
                <field name="timestamp"/>
                <field name="device_id"/>
                <field name="level"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_minio_device" model="ir.actions.act_window">
        <field name="name">Client Devices</field>
        <field name="res_model">minio.device</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False, 'delete': False, 'edit': False}</field>
    </record>
    
    <record id="action_minio_service_log" model="ir.actions.act_window">
        <field name="name">System Logs</field>
        <field name="res_model">minio.service.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False, 'delete': False, 'edit': False}</field>
    </record>

    <record id="action_minio_access_log" model="ir.actions.act_window">
        <field name="name">Access Logs</field>
        <field name="res_model">minio.access.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False, 'delete': False, 'edit': False}</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_minio_client_management" name="Client Management" parent="documents.menu_root" sequence="100"/>
    <menuitem id="menu_minio_device" name="Devices" parent="menu_minio_client_management" action="action_minio_device" sequence="10"/>
    <menuitem id="menu_minio_access_log" name="Access Logs" parent="menu_minio_client_management" action="action_minio_access_log" sequence="20"/>
    <menuitem id="menu_minio_service_log" name="System Logs" parent="menu_minio_client_management" action="action_minio_service_log" sequence="30"/>
</odoo>
